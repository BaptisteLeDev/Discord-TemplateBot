# Dependencies (Bun)
node_modules/

# Build outputs (Bun execute le TS, pas de build par defaut)
dist/
build/
*.tsbuildinfo
*.js.map

# Secrets en clair (jamais committes).
.env
.env.*
!.env.example
# .env.production est chiffre par dotenvx et committe : seule DOTENV_PRIVATE_KEY
# (hors repo) permet de le dechiffrer.
!.env.production
.env.keys
# Secrets locaux pour `act` (CI etage 2 en local) : JAMAIS committes.
.secrets
.secrets.*

# Artefacts d'analyse locale (CI etage 2 : CodeQL / SonarQube)
codeql-db/
*.sarif
.scannerwork/

