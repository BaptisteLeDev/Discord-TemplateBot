# Configuration du bot Discord.
# Copier ce fichier en .env et renseigner les valeurs (Bun charge .env automatiquement).

# Identifiants Discord (Developer Portal).
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here

# Guild de dev (optionnel) : si renseigne, deploy-commands cible cette guild
# (mise a jour instantanee). Sinon, deploiement global (jusqu'a 1h de propagation).
DISCORD_GUILD_ID=

# API HTTP (contrat monitoring /health + /stats).
PORT=3001
HOST=0.0.0.0

# Environnement : development | production | test.
NODE_ENV=development
