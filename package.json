{
  "name": "@botfactory/discord-template-bot",
  "version": "1.0.0",
  "description": "Professional Discord bot template with TypeScript, Fastify API, and best practices",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "deploy": "tsx src/deploy-commands.ts",
    "deploy:dev": "tsx src/deploy-commands.ts --dev",
    "deploy:prod": "tsx src/deploy-commands.ts --prod",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "prebuild": "pnpm run clean",
    "validate": "pnpm run type-check && pnpm run lint && pnpm run format:check && pnpm run test",
    "prepare": "pnpm run build"
  },
  "keywords": [
    "discord",
    "bot",
    "discord.js",
    "typescript",
    "template",
    "fastify",
    "api",
    "slash-commands"
  ],
  "author": "BotDiscordFactory",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.16.3",
    "@discordjs/voice": "^0.17.0",
    "fastify": "^5.2.0",
    "@fastify/swagger": "^9.3.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@fastify/cors": "^10.0.1",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "tsc-alias": "^1.8.10",
    "vitest": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "rimraf": "^6.0.1"
  }
}
